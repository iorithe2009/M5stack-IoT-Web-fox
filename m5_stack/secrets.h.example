#pragma once

// Wi-Fi 設定
static const char* WIFI_SSID     = "YOUR_WIFI_SSID";
static const char* WIFI_PASSWORD = "YOUR_WIFI_PASSWORD";

// MQTTブローカー設定
// MQTTブローカーがPC上のDockerで動いている場合、PCのLAN IPアドレスを指定します。
// 例: 192.168.11.x
//
// 【重要】M5Stack（外部デバイス）から接続する場合は Windows PC の LAN IP を使います。
//   WSL2 の IP（172.x.x.x）はホスト PC 内部からのアクセス用であり、M5Stack からは届きません。
//
// Windows PC の LAN IP を確認するには、Windows の cmd で以下を実行してください:
//
//   ipconfig
//
// 出力例:
//   イーサネット アダプター イーサネット:
//     IPv4 アドレス . . . : 192.168.11.X  <- この値を下の MQTT_HOST に設定する
//
// 【注意】有線LANとWi-Fiの両方がある場合、M5Stackと同じネットワーク（同じサブネット）の
//   アドレスを選んでください。M5StackのIPと先頭3オクテットが一致するものが正解です。
//   例: M5Stack が 192.168.11.y なら PC は 192.168.11.x のアドレスを使う
static const char* MQTT_HOST     = "YOUR_PC_LAN_IP";
static const uint16_t MQTT_PORT  = 1883;

// ブローカー認証（不要な場合は空文字のまま）
static const char* MQTT_USER     = "";
static const char* MQTT_PASSWORD = "";

// デバイスを識別するキー（サーバー側と一致させること）
static const char* DEVICE_KEY    = "m5-001";
